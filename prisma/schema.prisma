// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Users {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  validated Boolean  @default(true)
  createdAt DateTime @default(now())
  perfilId  Int      @default(1)
  informes  Informes[]
  perfil    Perfiles @relation(fields: [perfilId], references: [id])
}

model Perfiles {
  id    Int     @id
  tipo  String  @unique
  users Users[]
}


model Patients {
  dni        String   @id @default(uuid())
  nombre      String
  apellido    String
  age       Int
  email     String   @unique
  telefono String?
  createdAt DateTime @default(now())
  diagnoses  Diagnosis[]
}

model Doctors {
  id        String   @id @default(uuid())
  nombre      String
  apellido    String
  specialty   String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Diagnosis {
  id                      String   @id @default(uuid())
  sampleCode              String?  @unique
  patientId               String
  diagnosis               String
  material                String
  profesionalSolicitante String
  biopsasPrevias          Boolean
  createdAt               DateTime @default(now())

  patient                 Patients  @relation(fields: [patientId], references: [dni])
  informe                 Informes?
}

model DiagnosisSequence {
  year      Int @id
  lastValue Int @default(0)
}

model Informes {
  id          String    @id @default(uuid())
  cuerpo      String
  diagnosisId String    @unique
  userId      String
  createdAt   DateTime  @default(now())

  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id])
  user        Users     @relation(fields: [userId], references: [id])
  sharedLinks SharedReportLink[]
}

model SharedReportLink {
  id         String   @id @default(uuid())
  token      String   @unique
  password   String
  informeId  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  informe    Informes @relation(fields: [informeId], references: [id])
}